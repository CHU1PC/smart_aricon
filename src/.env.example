# このファイルを .env にコピーして値を入れる (.env は git 管理外)。
#   cp .env.example .env

# SwitchBot Cloud API 認証情報
#   取得: SwitchBot アプリ → プロフィール → 設定 →
#         「アプリバージョン」を10回タップ → 開発者向けオプション → Token / Secret
SWITCHBOT_TOKEN=
SWITCHBOT_SECRET=
SWITCHBOT_DEVICE_ID=

# 実エアコンに送信するときは false にする (既定は true = ログ出力のみ)
SWITCHBOT_MOCK=true

# --- 以下は検証用の任意設定 ---
# カメラのデバイス番号
# CAMERA_INDEX=0
# MOCK recognizer が返す user_id (unknown で未登録ルートを試せる)
# MOCK_RECOG=personA
# MOCK の DHT11 が返す値 (設定温度より高くすると冷房ルートを試せる)
# MOCK_TEMPERATURE=30
# MOCK_HUMIDITY=50
# Pi 以外でも実ハードを使いたい/強制 MOCK したいとき
# FORCE_MOCK_HW=true
